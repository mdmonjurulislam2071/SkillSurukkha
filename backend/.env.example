PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000,http://localhost:3001

DB_HOST=localhost
DB_PORT=3306
DB_NAME=skillshurokkha
DB_USER=root
DB_PASSWORD=
DB_CONNECTION_LIMIT=10

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
OTP_EXPIRES_MINUTES=10
OTP_RESEND_SECONDS=60
OTP_DEV_MODE=true

# Required for real email delivery. Keep blank in local OTP_DEV_MODE.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=SkillShurokkha <no-reply@skillshurokkha.com>

# Add an SMS provider adapter before production mobile OTP delivery.
SMS_PROVIDER=
SMS_API_KEY=
SMS_SENDER_ID=SkillShurokkha

# Optional initial admin account created at server startup.
ADMIN_NAME=SkillShurokkha Admin
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Hugging Face hosted inference for skill-video transcription.
HF_TOKEN=
HF_ASR_MODEL=openai/whisper-large-v3
HF_PROJECT_REVIEW_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct
HF_PROJECT_REVIEW_PROVIDER=auto
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
SKILL_VIDEO_MAX_MB=150
SKILL_ACTIVATION_SCORE=50
PROPOSAL_DOCUMENT_MAX_MB=5
PROJECT_ARCHIVE_MAX_MB=1024
PROJECT_REVIEW_MAX_FILES=250
PROJECT_REVIEW_MAX_SOURCE_BYTES=800000
PROJECT_REVIEW_MAX_EXTRACTED_MB=2048

# OpenAI Responses API for project requirement verification.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_PROJECT_REVIEW_MODEL=gpt-5.5
OPENAI_PROJECT_REVIEW_REASONING=medium
AI_CLIENT_PASS_SCORE=50
AI_PAYMENT_RELEASE_SCORE=70
AI_DISPUTE_HOLD_HOURS=24
CLIENT_REVIEW_DAYS=5
REVISION_REVIEW_DAYS=3
AI_INITIAL_RELEASE_PERCENT=90

# Background interval for overdue project detection and notifications.
DEADLINE_SYNC_INTERVAL_MS=60000

# Escrow payment providers. Hosted providers must point to real provider checkout/session URLs.
PAYMENT_PROVIDERS=dev_gateway,stripe,paypal,adyen,wise,bank_transfer,sslcommerz,bkash,nagad,rocket
PAYMENT_ENABLE_DEVELOPMENT_GATEWAY=true
PAYMENT_STRIPE_CHECKOUT_URL=
PAYMENT_PAYPAL_CHECKOUT_URL=
PAYMENT_ADYEN_CHECKOUT_URL=
PAYMENT_WISE_CHECKOUT_URL=
PAYMENT_SSLCOMMERZ_CHECKOUT_URL=
PAYMENT_NAGAD_CHECKOUT_URL=
PAYMENT_ROCKET_CHECKOUT_URL=
PAYMENT_WEBHOOK_SECRET=
PAYMENT_STRIPE_WEBHOOK_SECRET=
PAYMENT_PAYPAL_WEBHOOK_SECRET=
PAYMENT_ADYEN_WEBHOOK_SECRET=
PAYMENT_WISE_WEBHOOK_SECRET=
PAYMENT_SSLCOMMERZ_WEBHOOK_SECRET=
PAYMENT_BKASH_WEBHOOK_SECRET=
PAYMENT_NAGAD_WEBHOOK_SECRET=

# bKash PGW tokenized checkout. Use sandbox base URL for testing and merchant credentials from bKash.
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_CALLBACK_URL=http://localhost:5000/api/payments/bkash/callback
